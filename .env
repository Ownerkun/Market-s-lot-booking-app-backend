# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# auth-service
AUTH_DATABASE_URL="postgresql://auth_user:auth_password@auth-db:5432/auth_db?schema=public"

# market-service
MARKET_DATABASE_URL="postgresql://market_user:market_password@market-db:5432/market_db?schema=public"

# Shared variables
JWT_SECRET="test-key"
JWT_EXPIRES_IN="1h"
MARKET_SERVICE_PORT=3000